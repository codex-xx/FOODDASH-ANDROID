<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/customizeProductNameTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/customizeBasePriceTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textSize="14sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Quantity"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/customizeMinusButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/quantity_button_bg"
            android:contentDescription="Decrease quantity"
            android:src="@drawable/ic_remove" />

        <TextView
            android:id="@+id/customizeQuantityTextView"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="1"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/customizePlusButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/quantity_button_bg"
            android:contentDescription="Increase quantity"
            android:src="@drawable/ic_add" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Add-ons"
        android:textStyle="bold" />

    <CheckBox
        android:id="@+id/addOnOneCheckBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp" />

    <CheckBox
        android:id="@+id/addOnTwoCheckBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Preference"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/customPreferenceEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. no spicy, leave at gate"
        android:maxLines="2" />

</LinearLayout>
